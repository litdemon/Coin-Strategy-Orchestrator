{
    "python.testing.unittestArgs": [
        "-v",
        "-s",
        "./tests",
        "-p",
        "test_*.py"
    ],
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": true,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "entity.name.type.class",
                    "entity.name.class",
                    "entity.name.type",
                    "variable.other.class"
                ],
                "settings": {
                    "foreground": "#4EC9B0",
                    "fontStyle": "bold"
                }
            }
        ]
    }
}