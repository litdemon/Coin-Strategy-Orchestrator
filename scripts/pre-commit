#!/usr/bin/env python3
import os
import subprocess
import sys

VERSION_FILE = 'version'

def main():
    if not os.path.exists(VERSION_FILE):
        print(f"Warning: {VERSION_FILE} not found. Skipping version bump.")
        sys.exit(0)

    try:
        with open(VERSION_FILE, 'r') as f:
            content = f.read().strip()
            # Handle potential trailing characters
            if content.endswith('.'):
                content = content[:-1]
        
        parts = content.split('.')
        # Ensure at least 3 parts (major.minor.debug)
        while len(parts) < 3:
            parts.append('0')
        
        # Increment last part
        parts[-1] = str(int(parts[-1]) + 1)
        
        new_version = ".".join(parts)
        
        with open(VERSION_FILE, 'w') as f:
            f.write(new_version)
            
        print(f"[pre-commit] Bumped version to {new_version}")
        
        # Stage the file so it is included in the pending commit
        subprocess.run(['git', 'add', VERSION_FILE], check=True)
        
    except ValueError:
        print(f"Error: Could not parse version '{content}'")
        sys.exit(1)
    except Exception as e:
        print(f"Error in pre-commit version bump: {e}")
        sys.exit(1)

if __name__ == '__main__':
    main()
