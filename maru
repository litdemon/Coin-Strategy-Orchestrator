#!/usr/bin/env python3
import argparse
import time
import json
import sys
import os

# Add project root to sys.path
sys.path.append(os.getcwd())

from messaging.factory import MessagingFactory

def get_mqtt_client():
    config = {
        "broker_type": "mqtt",
        "mqtt": {
            "host": "mqtt.toybox7.net",
            "port": 1883,
            "client_id": f"maru_cli_{int(time.time())}"
        }
    }
    return MessagingFactory.create_client(config)

import uuid

def send_command(action, **kwargs):
    client = get_mqtt_client()
    if not client.connect():
        print("❌ Failed to connect to MQTT broker")
        return

    class CommandHandler:
        def __init__(self, client, action):
            self.client = client
            self.command_uuid = str(uuid.uuid4())
            self.responses = []
            self.action = action
            self.topic = f"trading/command/{self.command_uuid}"
            self.response_topic = f"trading/response/{self.command_uuid}/#"
        
        def on_response(self, topic, payload):
            # Pretty print JSON if possible
            if isinstance(payload, dict) or isinstance(payload, list):
                print(f"📥 Response:")
                print(json.dumps(payload, indent=2, ensure_ascii=False))
            else:
                print(f"📥 Response: {payload}")
            self.responses.append(payload)
        
        def get_response(self):
            return self.responses
        
        def send(self):
            payload = {"action": self.action, **kwargs}
            client.subscribe(self.response_topic, self.on_response)
            client.publish(self.topic, payload)
            print(f"📤 Sending {self.action.upper()} command (ID: {self.command_uuid})...")


    command_handler = CommandHandler(client, action)
    command_handler.send()
    
    # If status or account, wait for response?
    if action in ["status", "account"]:
        print("⏳ Waiting for response...")
            
        # Wait up to 3 seconds
        start = time.time()
        while time.time() - start < 3 and not command_handler.responses:
            time.sleep(0.1)
            
        if not command_handler.responses:
            print("❌ No response received (Timeout)")
            
    client.disconnect()

def main():
    parser = argparse.ArgumentParser(description="Maru Trading Agent CLI")
    subparsers = parser.add_subparsers(dest="command", required=True)

    # Status
    subparsers.add_parser("status", help="Get agent status")

    # Account
    subparsers.add_parser("account", help="Get account information")

    # Buy
    buy_parser = subparsers.add_parser("buy", help="Send Buy Command")
    buy_parser.add_argument("ticker", help="Ticker (e.g., KRW-BTC)")
    buy_parser.add_argument("price", type=float, nargs="?", help="Price (optional, defaults to current market price)")
    buy_group = buy_parser.add_mutually_exclusive_group(required=True)
    buy_group.add_argument("-v", "--volume", type=float, help="Volume in asset unit")
    buy_group.add_argument("-w", "--won", type=float, help="Volume in KRW")

    # Sell
    sell_parser = subparsers.add_parser("sell", help="Send Sell Command")
    sell_parser.add_argument("ticker", help="Ticker (e.g., KRW-BTC)")
    sell_parser.add_argument("price", type=float, nargs="?", help="Price (optional, defaults to current market price)")
    sell_group = sell_parser.add_mutually_exclusive_group(required=True)
    sell_group.add_argument("-v", "--volume", type=float, help="Volume in asset unit")
    sell_group.add_argument("-w", "--won", type=float, help="Volume in KRW")

    # Cancel
    cancel_parser = subparsers.add_parser("cancel", help="Cancel Order")
    cancel_parser.add_argument("uuid", help="Order UUID to cancel")

    args = parser.parse_args()

    if args.command == "status":
        send_command("status")
    elif args.command == "account":
        send_command("account")
    elif args.command == "buy":
        send_command("buy", ticker=args.ticker, volume=args.volume, won=args.won, price=args.price)
    elif args.command == "sell":
        send_command("sell", ticker=args.ticker, volume=args.volume, won=args.won, price=args.price)
    elif args.command == "cancel":
        send_command("cancel", uuid=args.uuid)

if __name__ == "__main__":
    main()
